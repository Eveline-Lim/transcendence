{
  "name": "authservice api",
  "description": "Authentication Service for the Transcendence Pong application.\nHandles JWT tokens, OAuth2/SSO, and session management.\n",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "fastify start --options index.js",
    "test": "c8 node --test unitTests/test/test-*.js",
    "dev": "node -r dotenv/config server.js",
	"generate:api": "openapi-generator-cli generate -i ../../docs/api/auth_service.yaml -g typescript-axios -o ./src/api"
  },
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@asyncapi/modelina": "^5.10.1",
	"@openapitools/openapi-generator-cli": "^2.19.0",
    "@seriousme/openapi-schema-validator": "^2.7.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.4",
    "fastify-openapi-glue": "^4.10.0",
    "fastify-plugin": "^5.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "c8": "^10.1.3",
    "expect-type": "^1.3.0",
    "fastify": "^5.6.2",
    "fastify-cli": "^7.4.1",
    "testcontainers": "^11.11.0",
    "typescript": "^5.9.3"
  }
}
